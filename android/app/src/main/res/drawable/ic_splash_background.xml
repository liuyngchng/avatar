<?xml version="1.0" encoding="utf-8"?>
<!-- Splash screen background — dark gradient matching app theme -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Radial gradient: lighter at center, darker at edges -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="76"
                android:type="radial">
                <item android:offset="0" android:color="#FF2D2D44" />
                <item android:offset="0.7" android:color="#FF1E1E35" />
                <item android:offset="1" android:color="#FF151528" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
